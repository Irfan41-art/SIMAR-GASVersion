{
  "entities": {
    "SchoolSettings": {
      "title": "School Settings",
      "description": "General settings for the school",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "principalName": { "type": "string" }
      },
      "required": ["schoolName", "principalName"]
    },
    "User": {
      "title": "User",
      "description": "User account information (Admin or Guru)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "nip": { "type": "string" },
        "subject": { "type": "string" },
        "classAssigned": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "guru"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "username", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record managed by a Guru",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "nisn": { "type": "string" },
        "nis": { "type": "string" },
        "class": { "type": "string" },
        "teacherId": { "type": "string" }
      },
      "required": ["name", "nisn", "nis", "class", "teacherId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "month": { "type": "string" },
        "year": { "type": "string" },
        "subject": { "type": "string" },
        "class": { "type": "string" },
        "session": { "type": "string" },
        "records": { "type": "object" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "subject", "class", "teacherId", "records"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Student assessment record",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "class": { "type": "string" },
        "title": { "type": "string" },
        "records": { "type": "object" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "class", "title", "teacherId", "records"]
    },
    "Journal": {
      "title": "Journal",
      "description": "Teacher's daily teaching journal",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "session": { "type": "string" },
        "presentCount": { "type": "number" },
        "absentCount": { "type": "number" },
        "status": { "type": "string", "enum": ["terlaksana", "tertunda"] },
        "material": { "type": "string" },
        "reflection": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "class", "subject", "teacherId"]
    }
  },
  "firestore": {
    "settings/school": {
      "schema": "SchoolSettings",
      "description": "Central school configuration"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance history"
    },
    "grades/{gradeId}": {
      "schema": "Grade",
      "description": "Assessment history"
    },
    "journals/{journalId}": {
      "schema": "Journal",
      "description": "Daily teaching journals"
    }
  }
}
